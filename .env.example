# Copy to .env and fill in real values

DATABASE_URL="postgresql://user:password@localhost:5432/clothing_brand"

JWT_ACCESS_SECRET="your-access-secret-min-8-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-8-chars"
JWT_ADMIN_ACCESS_SECRET="your-admin-access-secret"
JWT_ADMIN_REFRESH_SECRET="your-admin-refresh-secret"

FRONTEND_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# Optional: other services from your existing .env
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""

AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
