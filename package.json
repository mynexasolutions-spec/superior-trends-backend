{
  "name": "clothing-backend",
  "version": "1.0.0",
  "description": "Backend for Clothing Brand platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "seed": "tsx prisma/seed.ts",
    "seed:products": "tsx prisma/seed-products.ts",
    "seed:all": "tsx prisma/seed.ts && tsx prisma/seed-products.ts",
    "cleanup:mock": "tsx prisma/cleanup-mock-data.ts",
    "prisma:sync": "prisma db push && prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1",
    "twilio": "^5.0.4",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.15",
    "@types/streamifier": "^0.1.2",
    "prisma": "^5.12.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
